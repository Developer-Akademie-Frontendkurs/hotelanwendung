{
    "compilerOptions": {
        "target": "es2025",
        "module": "esnext",
        "lib": ["ES2025", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "moduleResolution": "bundler",
        "noImplicitReturns": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["src"]
}
